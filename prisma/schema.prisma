// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-arm64-openssl-3.0.x"] // 'native' para tu entorno local, 'linux-arm64-openssl-3.0.x' para Vercel
}

datasource db {
  provider = "sqlite"
}

model Order {
  id            String   @id @default(uuid())
  orderId       String   @unique
  productName   String
  quantity      Int
  totalAmount   Float
  paymentMethod String   // 'cod' or 'card'
  status        String   // 'pending', 'paid', 'delivered', 'cancelled'
  
  // Customer Info
  customerName  String
  email         String?
  phone         String
  address       String
  city          String
  postalCode    String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id            String   @id @default(uuid())
  companyName   String
  email         String
  phone         String
  volume        String
  createdAt     DateTime @default(now())
}
